{% stylesheet %}
.mens-slider {
  overflow: hidden;
  position: relative;
}

.mens-slider__track {
  display: flex;
  gap: 16px;
  transition: transform 0.6s ease;
}

.mens-slider__item {
  flex: 0 0 25%;
}

@media (max-width: 990px) {
  .mens-slider__item {
    flex: 0 0 50%;
  }
}

@media (max-width: 600px) {
  .mens-slider__item {
    flex: 0 0 100%;
  }
}
{% endstylesheet %}

<section class="page-width">
  <h2>{{ section.settings.heading }}</h2>

  <div class="mens-slider" data-slider>
    <div class="mens-slider__track">
      {% for product in section.settings.collection.products %}
        <div class="mens-slider__item">
          {% render 'card-product',
            card_product: product,
            media_aspect_ratio: 'square',
            show_secondary_image: true,
            show_vendor: false,
            show_rating: false
          %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const slider = document.querySelector('[data-slider]');
  if (!slider) return;

  const track = slider.querySelector('.mens-slider__track');
  const items = slider.querySelectorAll('.mens-slider__item');
  let index = 0;

  setInterval(() => {
    index++;
    if (index >= items.length - 3) {
      index = 0;
    }
    track.style.transform = `translateX(-${index * (items[0].offsetWidth + 16)}px)`;
  }, 2000);
});
</script>

{% schema %}
{
  "name": "Men's Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Men's Picks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Men's collection"
    }
  ],
  "presets": [
    {
      "name": "Men's Product Slider"
    }
  ]
}
{% endschema %}
