{% doc %}
  @prompt
    Create a custom section that can be added to a specific page. The section should be flexible and customizable with settings for heading, description text, background color, text color, padding, and alignment. Include options to add images or content blocks that can be arranged in different layouts.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_horizontal }}px;
    padding-right: {{ block.settings.padding_horizontal }}px;
  }

  .ai-custom-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-custom-section__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 600;
  }

  .ai-custom-section__description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.description_size }}px;
    margin: 0 0 {{ block.settings.description_spacing }}px;
    line-height: 1.6;
  }

  .ai-custom-section__content-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.content_gap }}px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-custom-section__content-{{ ai_gen_id }}--grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .ai-custom-section__content-{{ ai_gen_id }}--grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .ai-custom-section__content-{{ ai_gen_id }}--grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .ai-custom-section__content-{{ ai_gen_id }}--single {
    grid-template-columns: 1fr;
  }

  .ai-custom-section__content-item-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-custom-section__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.image_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-custom-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-custom-section__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-custom-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-custom-section__item-heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.item_heading_size }}px;
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-custom-section__item-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.item_text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-custom-section__content-{{ ai_gen_id }}--grid-3,
    .ai-custom-section__content-{{ ai_gen_id }}--grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-custom-section-{{ ai_gen_id }} {
      padding-left: 16px;
      padding-right: 16px;
    }

    .ai-custom-section__content-{{ ai_gen_id }}--grid-2,
    .ai-custom-section__content-{{ ai_gen_id }}--grid-3,
    .ai-custom-section__content-{{ ai_gen_id }}--grid-4 {
      grid-template-columns: 1fr;
    }

    .ai-custom-section__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-custom-section__description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.description_size }}px * 0.9);
    }
  }
{% endstyle %}

<div class="ai-custom-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-custom-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-custom-section__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-custom-section__description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    {% if block.settings.show_content %}
      <div class="ai-custom-section__content-{{ ai_gen_id }} ai-custom-section__content-{{ ai_gen_id }}--{{ block.settings.layout }}">
        {% for i in (1..4) %}
          {% liquid
            assign image_key = 'content_image_' | append: i
            assign heading_key = 'content_heading_' | append: i
            assign text_key = 'content_text_' | append: i
            assign show_key = 'show_content_' | append: i

            assign show_item = block.settings[show_key]
            assign item_image = block.settings[image_key]
            assign item_heading = block.settings[heading_key]
            assign item_text = block.settings[text_key]
          %}

          {% if show_item %}
            <div class="ai-custom-section__content-item-{{ ai_gen_id }}">
              {% if item_image != blank or block.settings.show_placeholder_images %}
                <div class="ai-custom-section__image-wrapper-{{ ai_gen_id }}">
                  {% if item_image != blank %}
                    <img
                      src="{{ item_image | image_url: width: 800 }}"
                      alt="{{ item_image.alt | escape }}"
                      loading="lazy"
                      width="{{ item_image.width }}"
                      height="{{ item_image.height }}"
                      class="ai-custom-section__image-{{ ai_gen_id }}"
                    >
                  {% else %}
                    <div class="ai-custom-section__image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if item_heading != blank %}
                <h3 class="ai-custom-section__item-heading-{{ ai_gen_id }}">
                  {{ item_heading }}
                </h3>
              {% endif %}

              {% if item_text != blank %}
                <div class="ai-custom-section__item-text-{{ ai_gen_id }}">
                  {{ item_text }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

