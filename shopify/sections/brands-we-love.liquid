{% stylesheet %}
.brands-we-love {
  padding: 60px 0;
}

.brands-we-love__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 30px;
}

.brands-we-love__title {
  font-size: 32px;
  font-weight: 400;
}

.brands-we-love__all {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
}

.brands-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}

.brand-card {
  text-align: center;
}

.brand-card__image {
  position: relative;
  overflow: hidden;
}

.brand-card__image img {
  width: 100%;
  height: auto;
  display: block;
}

.brand-card__logo {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-card__logo img {
  max-width: 120px;
  max-height: 60px;
}

.brand-card__link {
  margin-top: 12px;
  display: inline-block;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
}

/* Responsive */
@media (max-width: 990px) {
  .brands-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 600px) {
  .brands-grid {
    grid-template-columns: repeat(2, 1fr); /* 2x2 grid */
    gap: 12px;
  }

  .brands-we-love {
    padding: 24px 0;
  }

  .brand-card__logo img {
    max-width: 80px;
    max-height: 40px;
  }

  .brand-card__link {
    font-size: 11px;
  }
}

{% endstylesheet %}

<section class="brands-we-love page-width">
  <div class="brands-we-love__header">
    <h2 class="brands-we-love__title">{{ section.settings.heading }}</h2>

    {% if section.settings.all_link != blank %}
      <a class="brands-we-love__all" href="{{ section.settings.all_link }}">
        {{ section.settings.all_label }}
      </a>
    {% endif %}
  </div>

  <div class="brands-grid">
    {% for block in section.blocks %}

      {% assign brand_link = block.settings.link %}

      <div class="brand-card">
        
        {% if brand_link != blank %}
          <a href="{{ brand_link }}" class="brand-card__image-link">
        {% endif %}

        <div class="brand-card__image">
          {% if block.settings.image != blank %}
            {% assign brand_img = block.settings.image %}
            <img
              src="{{ brand_img | image_url: width: 800 }}"
              alt="{{ brand_img.alt | escape }}"
              width="{{ brand_img.width }}"
              height="{{ brand_img.height }}"
              loading="lazy"
            >
          {% endif %}

          {% if block.settings.logo != blank %}
            {% assign brand_logo = block.settings.logo %}
            <div class="brand-card__logo">
              <img
                src="{{ brand_logo | image_url: width: 300 }}"
                alt="{{ brand_logo.alt | escape }}"
                width="{{ brand_logo.width }}"
                height="{{ brand_logo.height }}"
                loading="lazy"
              >
            </div>
          {% endif %}
        </div>

        {% if brand_link != blank %}
          </a>
        {% endif %}

        {% if brand_link != blank %}
          <a href="{{ brand_link }}" class="brand-card__link">
            {{ block.settings.label }}
          </a>
        {% else %}
          <span class="brand-card__link">
            {{ block.settings.label }}
          </span>
        {% endif %}

      </div>
    {% endfor %}
  </div>
</section>


{% schema %}
{
  "name": "Brands We Love",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Brands We Love"
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "Top right link label",
      "default": "Shop All"
    },
    {
      "type": "url",
      "id": "all_link",
      "label": "Top right link URL"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Brand image"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Brand name",
          "default": "Brand Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Brands We Love"
    }
  ]
}
{% endschema %}
